pipeline {
    agent any

    environment {
        AWS_REGION        = 'ap-south-1'
        AWS_ACCOUNT_ID    = credentials('aws-account-id')
        ECR_REGISTRY      = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ECS_CLUSTER       = 'revcart-prod-cluster'
        IMAGE_TAG         = "latest"
        SONAR_PROJECT_KEY = 'com.revcart:revcart-microservices'
        SERVICES          = 'api-gateway,auth-service,user-service,product-service,cart-service,order-service,payment-service,notification-service,delivery-service,analytics-service,admin-service'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 120, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'github-credentials',
                    url: 'https://github.com/pratham20021/groceries-delivery-application.git'
                echo "Checkout complete"
            }
        }

        stage('Build Backend') {
            steps {
                dir('Rrevcart_P2-master/microservices') {
                    bat 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('Rrevcart_P2-master/revcart-frontend') {
                    bat 'npm ci'
                    bat 'npm run build -- --configuration=production'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('Rrevcart_P2-master/microservices') {
                    withSonarQubeEnv('SonarQube') {
                        withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                            bat "mvn sonar:sonar -Dsonar.token=%SONAR_TOKEN% -Dsonar.exclusions=**/target/**"
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                    bat """
                        ping -n 16 127.0.0.1 > nul
                        curl -sf -u %SONAR_TOKEN%: "http://localhost:9000/api/qualitygates/project_status?projectKey=%SONAR_PROJECT_KEY%" -o qg.json
                        type qg.json
                        findstr "\"status\":\"ERROR\"" qg.json && (echo Quality Gate FAILED && exit 1) || exit 0
                    """
                }
            }
        }

        stage('Create ECR Repos') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    script {
                        def services = env.SERVICES.split(',').toList() + ['frontend']
                        services.each { service ->
                            bat "aws ecr describe-repositories --repository-names revcart/${service} --region %AWS_REGION% 2>nul || aws ecr create-repository --repository-name revcart/${service} --region %AWS_REGION%"
                        }
                    }
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                script {
                    def services = env.SERVICES.split(',')
                    services.each { service ->
                        bat "docker build -t %ECR_REGISTRY%/revcart/${service}:latest -f Rrevcart_P2-master/microservices/${service}/Dockerfile Rrevcart_P2-master/microservices"
                    }
                    bat "docker build -t %ECR_REGISTRY%/revcart/frontend:latest Rrevcart_P2-master/revcart-frontend"
                }
            }
        }

        stage('Push to ECR') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    bat "aws ecr get-login-password --region %AWS_REGION% | docker login --username AWS --password-stdin %ECR_REGISTRY%"
                    script {
                        def services = env.SERVICES.split(',')
                        services.each { service ->
                            bat "docker push %ECR_REGISTRY%/revcart/${service}:latest"
                        }
                        bat "docker push %ECR_REGISTRY%/revcart/frontend:latest"
                    }
                }
            }
        }

        stage('Terraform Apply') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'db-password',           variable: 'TF_VAR_db_password'),
                    string(credentialsId: 'mail-username',         variable: 'TF_VAR_mail_username'),
                    string(credentialsId: 'mail-password',         variable: 'TF_VAR_mail_password'),
                    string(credentialsId: 'google-client-id',      variable: 'TF_VAR_google_client_id'),
                    string(credentialsId: 'google-client-secret',  variable: 'TF_VAR_google_client_secret')
                ]) {
                    dir('Rrevcart_P2-master/terraform') {
                        bat 'terraform init -input=false'
                        bat 'terraform validate'
                        bat 'terraform plan -input=false -out=tfplan -var="aws_region=%AWS_REGION%"'
                        bat 'terraform apply -input=false -auto-approve tfplan'
                        script {
                            env.ALB_DNS = bat(
                                script: 'terraform output -raw alb_dns_name',
                                returnStdout: true
                            ).trim()
                            echo "App deployed at: http://${env.ALB_DNS}"
                        }
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    bat "aws eks update-kubeconfig --region %AWS_REGION% --name %ECS_CLUSTER%"
                    dir('Rrevcart_P2-master/k8s') {
                        bat "kubectl apply -f namespace.yaml"
                        bat "kubectl apply -f configmap.yaml"
                        bat "kubectl apply -f secrets.yaml"
                        bat "kubectl apply -f infra/consul.yaml"
                        bat "kubectl apply -f infra/mysql.yaml"
                        bat "kubectl apply -f infra/mongodb.yaml"
                        bat "kubectl apply -f infra/redis.yaml"
                        bat "kubectl rollout status deployment/consul  -n revcart --timeout=120s"
                        bat "kubectl rollout status deployment/mysql   -n revcart --timeout=180s"
                        bat "kubectl rollout status deployment/mongodb -n revcart --timeout=180s"
                        bat "kubectl rollout status deployment/redis   -n revcart --timeout=120s"
                        script {
                            def services = env.SERVICES.split(',')
                            services.each { service ->
                                bat "powershell -Command \"(Get-Content services/${service}.yaml) -replace '<YOUR_REGISTRY>', '%ECR_REGISTRY%' | Set-Content services/${service}.yaml\""
                            }
                            bat "powershell -Command \"(Get-Content services/frontend.yaml) -replace '<YOUR_REGISTRY>', '%ECR_REGISTRY%' | Set-Content services/frontend.yaml\""
                        }
                        bat "kubectl apply -f services/"
                        bat "kubectl apply -f ingress.yaml"
                        bat "kubectl apply -f monitoring/prometheus.yaml"
                        bat "kubectl apply -f monitoring/grafana.yaml"
                    }
                }
            }
        }

        stage('Smoke Test') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    script {
                        def ingressIp = bat(
                            script: 'kubectl get ingress revcart-ingress -n revcart -o jsonpath="{.status.loadBalancer.ingress[0].hostname}"',
                            returnStdout: true
                        ).trim()
                        echo "App is live at: http://${ingressIp}"
                    }
                }
            }
        }

        stage('Start Monitoring') {
            steps {
                dir('Rrevcart_P2-master') {
                    bat 'docker compose up -d prometheus grafana'
                    echo "Prometheus : http://localhost:9090"
                    echo "Grafana    : http://localhost:3000  (admin/admin)"
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline SUCCESS - RevCart is deployed!"
        }
        failure {
            echo "Pipeline FAILED - check console output above"
        }
        always {
            bat 'docker logout || exit 0'
            cleanWs()
        }
    }
}
