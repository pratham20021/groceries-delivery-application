pipeline {
    agent any

    environment {
        AWS_REGION        = 'ap-south-1'
        AWS_ACCOUNT_ID    = credentials('aws-account-id')
        ECR_REGISTRY      = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        ECS_CLUSTER       = 'revcart-prod-cluster'
        IMAGE_TAG         = "latest"
        SONAR_PROJECT_KEY = 'revcart-microservices'
        SERVICES          = 'api-gateway,auth-service,user-service,product-service,cart-service,order-service,payment-service,notification-service,delivery-service,analytics-service,admin-service'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 120, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        // ── Stage 1: Checkout ─────────────────────────────────────────────────
        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: 'github-credentials',
                    url: 'https://github.com/pratham20021/groceries-delivery-application.git'
                echo "Checkout complete"
            }
        }

        // ── Stage 2: Build Backend ─────────────────────────────────────────────
        stage('Build Backend') {
            steps {
                dir('Rrevcart_P2-master/microservices') {
                    bat 'mvn clean package -DskipTests'
                }
            }
        }

        // ── Stage 3: Build Frontend ────────────────────────────────────────────
        stage('Build Frontend') {
            steps {
                dir('Rrevcart_P2-master/revcart-frontend') {
                    bat 'npm ci'
                    bat 'npm run build -- --configuration=production'
                }
            }
        }

        // ── Stage 4: SonarQube Analysis ───────────────────────────────────────
        stage('SonarQube Analysis') {
            steps {
                dir('Rrevcart_P2-master/microservices') {
                    withSonarQubeEnv('SonarQube') {
                        withCredentials([string(credentialsId: 'sonarqube-token', variable: 'SONAR_TOKEN')]) {
                            bat """
                                mvn sonar:sonar ^
                                    -Dsonar.projectKey=revcart ^
                                    -Dsonar.projectName="RevCart Microservices" ^
                                    -Dsonar.java.binaries=target/classes,api-gateway/target/classes,auth-service/target/classes,user-service/target/classes,product-service/target/classes,cart-service/target/classes,order-service/target/classes,payment-service/target/classes,notification-service/target/classes,delivery-service/target/classes,analytics-service/target/classes,admin-service/target/classes ^
                                    -Dsonar.exclusions=**/target/**,**/*.xml,**/*.json ^
                                    -Dsonar.login=%SONAR_TOKEN%
                            """
                        }
                    }
                }
            }
        }

        // ── Stage 5: Quality Gate ─────────────────────────────────────────────
        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // ── Stage 6: Create ECR Repositories ─────────────────────────────────
        stage('Create ECR Repos') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    script {
                        def services = env.SERVICES.split(',').toList() + ['frontend']
                        services.each { service ->
                            bat """
                                aws ecr describe-repositories --repository-names revcart/${service} --region %AWS_REGION% 2>nul || aws ecr create-repository --repository-name revcart/${service} --region %AWS_REGION%
                            """
                        }
                    }
                }
            }
        }

        // ── Stage 7: Build Docker Images ──────────────────────────────────────
        stage('Build Docker Images') {
            steps {
                script {
                    def services = env.SERVICES.split(',')
                    services.each { service ->
                        bat """
                            docker build ^
                                -t %ECR_REGISTRY%/revcart/${service}:%IMAGE_TAG% ^
                                -t %ECR_REGISTRY%/revcart/${service}:latest ^
                                Rrevcart_P2-master/microservices/${service}
                        """
                    }
                    bat """
                        docker build ^
                            -t %ECR_REGISTRY%/revcart/frontend:%IMAGE_TAG% ^
                            -t %ECR_REGISTRY%/revcart/frontend:latest ^
                            Rrevcart_P2-master/revcart-frontend
                    """
                }
            }
        }

        // ── Stage 8: Push Images to ECR ───────────────────────────────────────
        stage('Push to ECR') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    bat """
                        aws ecr get-login-password --region %AWS_REGION% | docker login --username AWS --password-stdin %ECR_REGISTRY%
                    """
                    script {
                        def services = env.SERVICES.split(',')
                        services.each { service ->
                            bat "docker push %ECR_REGISTRY%/revcart/${service}:%IMAGE_TAG%"
                            bat "docker push %ECR_REGISTRY%/revcart/${service}:latest"
                        }
                        bat "docker push %ECR_REGISTRY%/revcart/frontend:%IMAGE_TAG%"
                        bat "docker push %ECR_REGISTRY%/revcart/frontend:latest"
                    }
                }
            }
        }

        // ── Stage 9: Terraform Apply ───────────────────────────────────────────
        stage('Terraform Apply') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'db-password',           variable: 'TF_VAR_db_password'),
                    string(credentialsId: 'mail-username',         variable: 'TF_VAR_mail_username'),
                    string(credentialsId: 'mail-password',         variable: 'TF_VAR_mail_password'),
                    string(credentialsId: 'google-client-id',      variable: 'TF_VAR_google_client_id'),
                    string(credentialsId: 'google-client-secret',  variable: 'TF_VAR_google_client_secret')
                ]) {
                    dir('Rrevcart_P2-master/terraform') {
                        bat 'terraform init -input=false'
                        bat 'terraform validate'
                        bat 'terraform plan -input=false -out=tfplan -var="aws_region=%AWS_REGION%"'
                        bat 'terraform apply -input=false -auto-approve tfplan'
                        script {
                            env.ALB_DNS = bat(
                                script: 'terraform output -raw alb_dns_name',
                                returnStdout: true
                            ).trim()
                            echo "App deployed at: http://${env.ALB_DNS}"
                        }
                    }
                }
            }
        }

        // ── Stage 10: Deploy to ECS ────────────────────────────────────────────
        stage('Deploy to ECS') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    script {
                        def services = env.SERVICES.split(',').toList() + ['frontend']
                        services.each { service ->
                            bat """
                                aws ecs update-service ^
                                    --cluster %ECS_CLUSTER% ^
                                    --service revcart-prod-${service} ^
                                    --force-new-deployment ^
                                    --region %AWS_REGION%
                            """
                        }
                        echo "Waiting for all ECS services to stabilize..."
                        services.each { service ->
                            bat """
                                aws ecs wait services-stable ^
                                    --cluster %ECS_CLUSTER% ^
                                    --services revcart-prod-${service} ^
                                    --region %AWS_REGION%
                            """
                        }
                    }
                }
            }
        }

        // ── Stage 11: Smoke Test ──────────────────────────────────────────────
        stage('Smoke Test') {
            steps {
                withCredentials([
                    string(credentialsId: 'aws-access-key-id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws-secret-access-key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    script {
                        def albDns = bat(
                            script: """
                                aws elbv2 describe-load-balancers ^
                                    --names revcart-prod-alb ^
                                    --region %AWS_REGION% ^
                                    --query "LoadBalancers[0].DNSName" ^
                                    --output text
                            """,
                            returnStdout: true
                        ).trim()
                        echo "App is live at: http://${albDns}"
                    }
                }
            }
        }

        // ── Stage 12: Start Monitoring ────────────────────────────────────────
        stage('Start Monitoring') {
            steps {
                dir('Rrevcart_P2-master') {
                    bat 'docker compose up -d prometheus grafana'
                    echo "Prometheus : http://localhost:9090"
                    echo "Grafana    : http://localhost:3000  (admin/admin)"
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline SUCCESS — RevCart is deployed!"
        }
        failure {
            echo "Pipeline FAILED — check console output above"
        }
        always {
            bat 'docker logout || exit 0'
            cleanWs()
        }
    }
}
