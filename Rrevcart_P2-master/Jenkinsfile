pipeline {
    agent any

    environment {
        DOCKER_HUB_USERNAME = 'pratham20021'
        DOCKER_CREDENTIALS_ID = 'dockerhub-credentials'
        GITHUB_CREDENTIALS_ID = 'github-credentials'
        IMAGE_TAG = "latest"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    credentialsId: "${GITHUB_CREDENTIALS_ID}",
                    url: 'https://github.com/pratham20021/groceries-delivery-application.git'
            }
        }

        stage('Build Backend') {
            steps {
                dir('Rrevcart_P2-master/microservices') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('Rrevcart_P2-master/revcart-frontend') {
                    sh 'npm install'
                    sh 'npm run build'
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                script {
                    def services = [
                        'api-gateway', 'auth-service', 'user-service',
                        'product-service', 'cart-service', 'order-service',
                        'payment-service', 'notification-service', 'delivery-service',
                        'analytics-service', 'admin-service'
                    ]
                    services.each { service ->
                        sh "docker build -t ${DOCKER_HUB_USERNAME}/revcart-${service}:${IMAGE_TAG} ./Rrevcart_P2-master/microservices/${service}"
                    }
                    sh "docker build -t ${DOCKER_HUB_USERNAME}/revcart-frontend:${IMAGE_TAG} ./Rrevcart_P2-master/revcart-frontend"
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: "${DOCKER_CREDENTIALS_ID}",
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'echo "$DOCKER_PASS" | docker login -u "$DOCKER_USER" --password-stdin'
                    script {
                        def services = [
                            'api-gateway', 'auth-service', 'user-service',
                            'product-service', 'cart-service', 'order-service',
                            'payment-service', 'notification-service', 'delivery-service',
                            'analytics-service', 'admin-service'
                        ]
                        services.each { service ->
                            sh "docker push ${DOCKER_HUB_USERNAME}/revcart-${service}:${IMAGE_TAG}"
                        }
                        sh "docker push ${DOCKER_HUB_USERNAME}/revcart-frontend:${IMAGE_TAG}"
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                withCredentials([
                    string(credentialsId: 'mail-username',       variable: 'MAIL_USERNAME'),
                    string(credentialsId: 'mail-password',       variable: 'MAIL_PASSWORD'),
                    string(credentialsId: 'google-client-id',    variable: 'GOOGLE_CLIENT_ID'),
                    string(credentialsId: 'google-client-secret',variable: 'GOOGLE_CLIENT_SECRET')
                ]) {
                    sh '''
                        cd Rrevcart_P2-master
                        docker-compose down --remove-orphans
                        docker-compose up -d
                    '''
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline executed successfully! RevCart is live.'
        }
        failure {
            echo 'Pipeline failed! Check the logs above for details.'
        }
        always {
            sh 'docker logout'
            cleanWs()
        }
    }
}
